#### [docker-compose.yml](file:///home/sebastian-agudelo/Documentos/code/langchain/docker-compose.yml)
```yaml
services:
  ollama:
    image: ollama/ollama:latest
    container_name: ollama
    ports:
      - "11434:11434"
    volumes:
      - ollama_data:/root/.ollama

  ollama-pull:
    image: ollama/ollama:latest
    container_name: ollama-pull
    depends_on:
      - ollama
    entrypoint: >
      sh -c "
        sleep 10 &&
        ollama pull llama3.2:1b &&
        ollama pull nomic-embed-text &&
        touch /tmp/models-ready &&
        sleep infinity
      "
    environment:
      - OLLAMA_HOST=ollama:11434
    healthcheck:
      test: ["CMD", "test", "-f", "/tmp/models-ready"]
      interval: 5s
      timeout: 3s
      retries: 60

  app:
    build: .
    container_name: langchain-rag
    depends_on:
      ollama-pull:
        condition: service_healthy
    volumes:
      - ./docs:/app/docs
      - ./data:/app/data
    environment:
      - OLLAMA_MODEL=llama3.2:1b
      - OLLAMA_EMBED_MODEL=nomic-embed-text
      - OLLAMA_BASE_URL=http://ollama:11434
      - DOCS_PATH=/app/docs
      - CHROMA_PATH=/app/data/chroma
      - CHUNK_SIZE=500
      - CHUNK_OVERLAP=50
    stdin_open: true
    tty: true

volumes:
  ollama_data:
```

