from langchain_ollama import OllamaEmbeddings
from app.config import OLLAMA_BASE_URL, OLLAMA_EMBED_MODEL

def get_embeddings() -> OllamaEmbeddings:
    return OllamaEmbeddings(
        model=OLLAMA_EMBED_MODEL,
        base_url=OLLAMA_BASE_URL,
    )
```

#### [app/rag/loader.py](file:///home/sebastian-agudelo/Documentos/code/langchain/app/rag/loader.py)
```python
import os
from langchain_community.document_loaders import PyPDFLoader
from app.config import DOCS_PATH

def load_pdfs() -> list:
    docs = []
    pdf_files = [f for f in os.listdir(DOCS_PATH) if f.endswith(".pdf")]
    if not pdf_files:
        return docs
    for filename in pdf_files:
        filepath = os.path.join(DOCS_PATH, filename)
        loader = PyPDFLoader(filepath)
        docs.extend(loader.load())
    return docs
```

#### [app/rag/splitter.py](file:///home/sebastian-agudelo/Documentos/code/langchain/app/rag/splitter.py)
```python
from langchain.text_splitter import RecursiveCharacterTextSplitter
from app.config import CHUNK_SIZE, CHUNK_OVERLAP

def split_documents(docs: list) -> list:
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=CHUNK_SIZE,
        chunk_overlap=CHUNK_OVERLAP,
        separators=["\n\n", "\n", " ", ""],
    )
    return splitter.split_documents(docs)
```

#### [app/rag/vectorstore.py](file:///home/sebastian-agudelo/Documentos/code/langchain/app/rag/vectorstore.py)
```python
import os
from langchain_community.vectorstores import Chroma
from app.config import CHROMA_PATH
from app.rag.embeddings import get_embeddings

def create_vectorstore(chunks: list) -> Chroma:
    if os.path.exists(CHROMA_PATH):
        import shutil
        shutil.rmtree(CHROMA_PATH)
    embeddings = get_embeddings()
    batch_size = 5
    vectorstore = None
    for i in range(0, len(chunks), batch_size):
        batch = chunks[i:i + batch_size]
        if vectorstore is None:
            vectorstore = Chroma.from_documents(
                documents=batch, embedding=embeddings,
                persist_directory=CHROMA_PATH,
            )
        else:
            vectorstore.add_documents(batch)
    return vectorstore

def load_vectorstore() -> Chroma | None:
    if not os.path.exists(CHROMA_PATH):
        return None
    embeddings = get_embeddings()
    vectorstore = Chroma(persist_directory=CHROMA_PATH, embedding_function=embeddings)
    count = vectorstore._collection.count()
    if count == 0:
        return None
    return vectorstore
```

#### [app/rag/chain.py](file:///home/sebastian-agudelo/Documentos/code/langchain/app/rag/chain.py)
```python
from langchain_ollama import ChatOllama
from langchain.prompts import ChatPromptTemplate
from langchain.schema.runnable import RunnablePassthrough
from langchain.schema.output_parser import StrOutputParser
from app.config import OLLAMA_BASE_URL, OLLAMA_MODEL

RAG_PROMPT = ChatPromptTemplate.from_template("""
Contexto:
{context}

Pregunta: {question}

Responde basándote solo en el contexto anterior. Sé breve y directo.
Respuesta:
""")

def format_docs(docs: list) -> str:
    return "\n\n---\n\n".join(doc.page_content for doc in docs)

def build_rag_chain(vectorstore):
    retriever = vectorstore.as_retriever(
        search_type="similarity", search_kwargs={"k": 2},
    )
    llm = ChatOllama(
        model=OLLAMA_MODEL, base_url=OLLAMA_BASE_URL,
        temperature=0.3, num_predict=256,
    )
    chain = (
        {"context": retriever | format_docs, "question": RunnablePassthrough()}
        | RAG_PROMPT | llm | StrOutputParser()
    )
    return chain
```

#### [app/main.py](file:///home/sebastian-agudelo/Documentos/code/langchain/app/main.py)
```python
import sys, time
from rich.console import Console
from rich.panel import Panel
from rich.markdown import Markdown
from app.rag.loader import load_pdfs
from app.rag.splitter import split_documents
from app.rag.vectorstore import create_vectorstore, load_vectorstore
from app.rag.chain import build_rag_chain

console = Console()

def wait_for_ollama():
    import urllib.request
    from app.config import OLLAMA_BASE_URL
    for attempt in range(30):
        try:
            urllib.request.urlopen(f"{OLLAMA_BASE_URL}/api/tags", timeout=2)
            return True
        except Exception:
            time.sleep(2)
    return False

def index_documents():
    docs = load_pdfs()
    if not docs: return None
    chunks = split_documents(docs)
    return create_vectorstore(chunks)

def chat_loop(chain):
    while True:
        try:
            question = console.input("\n[bold cyan]❓ Pregunta:[/] ")
        except (KeyboardInterrupt, EOFError):
            break
        if question.strip().lower() in ("salir", "exit", "quit", "q"):
            break
        if not question.strip(): continue
        try:
            answer = chain.invoke(question)
            console.print(Panel(Markdown(answer), title="🧠 Respuesta", border_style="green"))
        except Exception as e:
            console.print(f"❌ Error: {e}", style="red")

def main():
    if not wait_for_ollama(): sys.exit(1)
    vectorstore = load_vectorstore()
    if vectorstore is None:
        vectorstore = index_documents()
        if vectorstore is None: sys.exit(1)
    chain = build_rag_chain(vectorstore)
    chat_loop(chain)

if __name__ == "__main__":
    main()
```

